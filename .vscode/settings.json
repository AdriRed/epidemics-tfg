{
    "fortran.linter.includePaths": ["${workspaceFolder}/include", "${workspaceFolder}"],
    "fortran.fortls.disabled": false,
    "fortran.fortls.configure": "${workspaceFolder/fortls.config.json",
    "[FortranFreeForm]": {
        "editor.insertSpaces": true,
        "editor.indentSize": 3,
        "editor.rulers": [132]
    },
    "fortran.linter.initialize": true
}